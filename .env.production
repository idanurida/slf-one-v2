# .env.production - Copy to .env on VPS before deployment
# Database Configuration
DB_HOST=db
DB_PORT=5432
DB_NAME=slf_one
DB_USER=slf_user
DB_PASSWORD=slf_pass
DB_DIALECT=postgres

# JWT Configuration
JWT_SECRET=CHANGE_ME_TO_RANDOM_64_CHAR_STRING
JWT_EXPIRES_IN=24h

# Server Configuration
PORT=5000
NODE_ENV=production

# CORS
CORS_ORIGIN=https://slf-manager.skicreative.net

# Client Configuration
NEXT_PUBLIC_API_URL=http://server:5000/api
